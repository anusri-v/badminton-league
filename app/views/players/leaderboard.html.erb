<div class="page-container">
  <div class="page-header">
    <%= link_to "← Back", root_path, class: "back-link" %>
    <br /><br />
    <h1>Leaderboard</h1>
  </div>

  <table class="data-table">
    <thead>
      <tr>
        <th>#</th>
        <th>Name</th>
        <th>Phone</th>
        <th>Email</th>
        <th>Wins</th>
        <th>Losses</th>
      </tr>
    </thead>
    <tbody>
      <% if @players.empty? %>
        <tr><td colspan="5" class="empty">No players found.</td></tr>
      <% else %>
        <% @players.each_with_index do |player, i| %>
          <tr>
            <td><%= (@page - 1) * @per_page + i + 1 %></td>
            <td><%= player.name %></td>
            <td><%= player.phone %></td>
            <td><%= player.email %></td>
            <td><%= player.win_count %></td>
            <td><%= player.loss_count %></td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>

  <div class="pagination">
    <% if @page > 1 %>
      <%= link_to "← Prev", players_path(leaderboard: true, page: @page - 1, per_page: @per_page), class: "page-btn" %>
    <% end %>
    <span>Page <%= @page %> of <%= [(@count.to_f / @per_page).ceil, 1].max %></span>
    <% if @page * @per_page < @count %>
      <%= link_to "Next →", players_path(leaderboard: true, page: @page + 1, per_page: @per_page), class: "page-btn" %>
    <% end %>
  </div>
</div>
