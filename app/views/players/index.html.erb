<div class="page-container">
  <div class="page-header">
    <%= link_to "← Back", root_path, class: "back-link" %>
    <br /><br />
    <h1>Players</h1>
  </div>

  <table class="data-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Phone</th>
        <th>Gender</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if @players.empty? %>
        <tr><td colspan="5" class="empty">No players found.</td></tr>
      <% else %>
        <% @players.each do |player| %>
          <tr>
            <td><%= player.name %></td>
            <td><%= player.email %></td>
            <td><%= player.phone %></td>
            <td><%= player.gender %></td>
            <td><%= button_to "Delete", player_path(player), method: :delete, class: "delete-btn", data: { turbo_confirm: "Delete #{player.name}?" } %></td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>

  <div class="pagination">
    <% if @page > 1 %>
      <%= link_to "← Prev", players_path(page: @page - 1, per_page: @per_page), class: "page-btn" %>
    <% end %>
    <span>Page <%= @page %> of <%= [(@count.to_f / @per_page).ceil, 1].max %></span>
    <% if @page * @per_page < @count %>
      <%= link_to "Next →", players_path(page: @page + 1, per_page: @per_page), class: "page-btn" %>
    <% end %>
  </div>
</div>
