<div class="page-container">
  <div class="page-header">
    <%= link_to "← Back", root_path, class: "back-link" %>
    <br /><br />
    <h1>Record Match</h1>
  </div>

  <% if @error %>
    <div class="form-errors">
      <p><%= @error %></p>
    </div>
  <% end %>

  <%= form_with url: matches_path, method: :post, class: "player-form" do |f| %>
    <div class="form-group">
      <label>Player 1</label>
      <%= f.select :player_1_id, @players.map { |p| [p.name, p.id] }, { include_blank: "Select player 1" } %>
    </div>
    <div class="form-group">
      <label>Player 2</label>
      <%= f.select :player_2_id, @players.map { |p| [p.name, p.id] }, { include_blank: "Select player 2" } %>
    </div>
    <div class="form-group">
      <label>Winner</label>
      <%= f.select :winner_id, @players.map { |p| [p.name, p.id] }, { include_blank: "Select winner" } %>
    </div>
    <%= f.submit "Record Match", class: "btn" %>
  <% end %>
</div>
